# Copy to config/local.env (gitignored), tweak, then:
#
#   source config/local.env
#   make seed              # seed users + pull fixtures/tokens.json
#   make reads-all-smoke   # run
#
# This file is the single place a fresh clone needs to fill in. Every var is
# `export`ed so the Makefile and helper scripts pick it up after `source`.

# ── API target (Locust hits this over HTTP) ─────────────────────────────────
export HOST=http://localhost:8000
export LOAD_TEST_TOKEN_FIXTURE=fixtures/tokens.json

# ── Seeding ─────────────────────────────────────────────────────────────────
# Seeding runs scripts/seed_users.py inside the backend's Django shell (it
# needs the ORM + model signals) — it does NOT write to the DB directly.
#
# SSH_HOST empty  → backend runs in docker on THIS machine; seed.sh uses
#                   `docker exec` directly (no SSH).
export SSH_HOST=
# Name of the Django container (see `docker ps`).
export DJANGO_CONTAINER=easychef-dc01
# Path the seed writes inside the container (copied out automatically).
export REMOTE_FIXTURE_PATH=/tmp/load_test_tokens.json

# ── Seed tuning ─────────────────────────────────────────────────────────────
export LOAD_TEST_COUNT=50
# Per-user data volumes (pantry/products reads filter to APPROVED products).
export LOAD_TEST_PANTRY_ITEMS=100
export LOAD_TEST_MY_RECIPES=50
export LOAD_TEST_COOKBOOKS=50
export LOAD_TEST_COOKBOOK_RECIPES=100
export LOAD_TEST_COMMUNITY_COOKBOOKS=100
export LOAD_TEST_RECOMMENDED=100
export LOAD_TEST_CART_ITEMS=100
export LOAD_TEST_NOTIFICATIONS=100
export LOAD_TEST_MY_PRODUCTS=50

# ── Locust run defaults (override on the CLI too) ───────────────────────────
export USERS=10
export SPAWN_RATE=5
export RUN_TIME=60s

# ── Optional: direct DB access for monitoring during a run ──────────────────
# Used ONLY by `make watch-db` (samples pg_stat_activity). NOT used for seeding.
# export DATABASE_URL=postgres://easychef:easychef@localhost:5432/easychef
