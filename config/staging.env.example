# Copy to config/staging.env (gitignored), fill in, then:
#
#   source config/staging.env
#   make seed              # seed over SSH + pull fixtures/tokens.json locally
#   make reads-all-ramp    # run against staging
#
# Before seeding staging, follow RUNBOOK Part 2: enable LOAD_TEST_MODE on the
# backend, verify the external-client mocks applied, and post the heads-up in
# #engineering. Every var below is `export`ed so `source` propagates it.

# ── API target (Locust hits this over HTTP) ─────────────────────────────────
export HOST=https://staging-api.your-domain
export LOAD_TEST_TOKEN_FIXTURE=fixtures/tokens.json

# ── Seeding ─────────────────────────────────────────────────────────────────
# Seeding runs scripts/seed_users.py inside the backend's Django shell over SSH
# (it needs the ORM + model signals) — it does NOT connect to the DB directly.
#
# SSH_HOST: ssh target for the backend host — an ~/.ssh/config alias or
#           user@host. Non-empty → seed.sh runs `ssh <host> docker exec ...`
#           and scp's the resulting fixture back to fixtures/tokens.json.
export SSH_HOST=staging-host
# Extra ssh/scp flags (keepalive, identity file, jump host, alt port, ...).
export SSH_OPTS="-o ServerAliveInterval=60"
export DJANGO_CONTAINER=easychef-dc01
export REMOTE_FIXTURE_PATH=/tmp/load_test_tokens.json

# ── Seed tuning ─────────────────────────────────────────────────────────────
export LOAD_TEST_COUNT=50
export LOAD_TEST_PANTRY_ITEMS=100
export LOAD_TEST_MY_RECIPES=50
export LOAD_TEST_COOKBOOKS=50
export LOAD_TEST_COOKBOOK_RECIPES=100
export LOAD_TEST_COMMUNITY_COOKBOOKS=100
export LOAD_TEST_RECOMMENDED=100
export LOAD_TEST_CART_ITEMS=100
export LOAD_TEST_NOTIFICATIONS=100
export LOAD_TEST_MY_PRODUCTS=50

# ── Locust run defaults (override on the CLI too) ───────────────────────────
export USERS=50
export SPAWN_RATE=10
export RUN_TIME=5m

# ── Optional: direct DB access for monitoring during a run ──────────────────
# Used ONLY by `make watch-db` (samples pg_stat_activity). NOT used for seeding.
# Staging PG is managed + behind PgBouncer, so connections consume pool slots
# and may be firewalled to specific IPs — use sparingly.
# export DATABASE_URL=postgres://user:pass@db-host:25060/dbname?sslmode=require
